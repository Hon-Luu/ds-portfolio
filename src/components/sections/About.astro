---
---

<section id="about" class="py-24 bg-stone-50">
  <div class="max-w-5xl mx-auto px-6">

    <h2 class="text-3xl font-bold text-stone-900 mb-2" data-reveal="up">About</h2>
    <div class="w-8 h-0.5 bg-teal-700 mb-10" data-reveal="line"></div>

    <!-- Top row: bio + leadership scope -->
    <div class="grid md:grid-cols-2 gap-12 mb-14">
      <div class="space-y-4 text-stone-600 leading-relaxed">
        <p data-reveal="up" data-delay="1">
          I'm a Director-level Data & Analytics leader with 10+ years of experience in insurance
          and financial services, currently based in Hong Kong leading APAC analytics at Chubb Life.
        </p>
        <p data-reveal="up" data-delay="2">
          I manage a cross-border engineering team in India and work directly with senior
          management across Southeast Asia — translating regional business priorities into
          analytics strategy and ensuring delivery teams execute against them. My work spans
          governance, transformation programmes, and ML systems that change how organisations
          distribute insurance, manage risk, and serve customers.
        </p>
        <p data-reveal="up" data-delay="3">
          I care about analytics that actually changes decisions — not dashboards that get ignored.
          That means being close to the business, clear about what gets built and why, and rigorous
          about whether it worked.
        </p>
      </div>

      <!-- Leadership scope callout -->
      <div class="bg-white rounded-xl p-6 border border-stone-200 self-start" data-reveal="right" data-delay="2">
        <h3 class="text-xs font-mono uppercase tracking-widest text-teal-700 mb-5">
          Leadership Scope
        </h3>
        <ul class="space-y-5">
          <li class="flex gap-3">
            <svg class="w-4 h-4 text-stone-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <p class="text-sm font-semibold text-stone-800">Engineering Team — India</p>
              <p class="text-xs text-stone-500 mt-0.5 leading-relaxed">Manages a team of 10+ engineers, BI developers, data analysts, and Scrum Masters. Sets priorities, technical delivery direction, timelines, and quality standards.</p>
            </div>
          </li>
          <li class="flex gap-3">
            <svg class="w-4 h-4 text-stone-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
            </svg>
            <div>
              <p class="text-sm font-semibold text-stone-800">Senior Management — Southeast Asia</p>
              <p class="text-xs text-stone-500 mt-0.5 leading-relaxed">Oversees Market Data Heads and senior management projects across all 8 APAC markets. Provides strategic guidance and direction, and aligns analytics strategy with regional business and distribution leadership.</p>
            </div>
          </li>
          <li class="flex gap-3">
            <svg class="w-4 h-4 text-stone-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <div>
              <p class="text-sm font-semibold text-stone-800">Product & Pricing Consulting</p>
              <p class="text-xs text-stone-500 mt-0.5 leading-relaxed">Provided consulting services to market directors, compliance, and IT teams on pricing recommendations and analytics strategy for insurance rate reviews.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Geographic Scope -->
    <div class="mb-14" data-reveal="up" data-delay="2">
      <h3 class="text-xs font-mono uppercase tracking-widest text-teal-700 mb-6">Geographic Scope</h3>
      <div class="grid sm:grid-cols-2 gap-6">

        <!-- United States -->
        <div class="bg-white border border-stone-200 rounded-xl p-5">
          <p class="text-xs font-mono uppercase tracking-widest text-stone-400 mb-3">United States</p>
          <div class="flex flex-wrap gap-2">
            {['Boston, MA', 'Chicago, IL', 'Dallas, TX'].map(m => (
              <span class="text-sm text-stone-700 bg-stone-50 border border-stone-200 px-3 py-1 rounded-full">{m}</span>
            ))}
          </div>
          <p class="text-xs text-stone-400 mt-3">Liberty Mutual · Kemper · Hallmark Financial</p>
        </div>

        <!-- Asia Pacific -->
        <div class="bg-white border border-stone-200 rounded-xl p-5">
          <p class="text-xs font-mono uppercase tracking-widest text-stone-400 mb-3">Asia Pacific</p>
          <div class="flex flex-wrap gap-2">
            {['Hong Kong', 'Indonesia', 'Vietnam', 'Thailand', 'New Zealand', 'Taiwan'].map(m => (
              <span class="text-sm text-stone-700 bg-teal-50 border border-teal-200 px-3 py-1 rounded-full">{m}</span>
            ))}
          </div>
          <p class="text-xs text-stone-400 mt-3">Chubb Life · AlikeAudience</p>
        </div>

      </div>
    </div>

    <!-- How I Lead -->
    <div data-reveal="up" data-delay="2">
      <h3 class="text-xs font-mono uppercase tracking-widest text-teal-700 mb-6">How I Lead</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          {
            step: '01',
            title: 'Set Direction',
            body: 'Define what needs to be built and why it matters to the business — not just a ticket, but a clear strategic objective the team can orient around.',
          },
          {
            step: '02',
            title: 'Explain the Rationale',
            body: 'Share the business context behind every priority so the team understands the trade-offs, not just the task. Informed engineers make better decisions.',
          },
          {
            step: '03',
            title: 'Define the Approach',
            body: 'Work through the how — data sources, modelling methodology, tooling, and integration — so execution is grounded in a shared technical understanding.',
          },
          {
            step: '04',
            title: 'Hold the Timeline',
            body: 'Set milestones, track progress, and remove blockers proactively. Delivery without accountability is just activity.',
          },
        ].map((item) => (
          <div class="bg-white border border-stone-200 border-t-2 border-t-teal-600 rounded-xl p-5">
            <p class="text-xs font-mono text-teal-400 mb-2">{item.step}</p>
            <p class="font-semibold text-stone-900 mb-2">{item.title}</p>
            <p class="text-sm text-stone-500 leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom row: open to + education + contact -->
    <div class="grid sm:grid-cols-3 gap-10 mt-14" data-reveal="up" data-delay="3">
      <div>
        <h3 class="text-xs font-mono uppercase tracking-widest text-teal-700 mb-3">Open to</h3>
        <ul class="space-y-2 text-sm text-stone-600">
          <li>— Director / Head of Data & Analytics</li>
          <li>— CDO pipeline roles</li>
          <li>— Analytics transformation consulting</li>
          <li>— Insurance & financial services</li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-mono uppercase tracking-widest text-teal-700 mb-3">Education</h3>
        <ul class="space-y-2 text-sm text-stone-600">
          <li>M.S. Data Science</li>
          <li class="text-stone-400 text-xs">Northwestern University</li>
          <li class="mt-2">B.A. Mathematics</li>
          <li class="text-stone-400 text-xs">University of Oklahoma</li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-mono uppercase tracking-widest text-teal-700 mb-3">Contact</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://linkedin.com/in/honluu" target="_blank" rel="noopener noreferrer"
              class="text-teal-700 hover:text-teal-900 hover:underline underline-offset-2">
              linkedin.com/in/honluu
            </a>
          </li>
          <li>
            <a href="mailto:hluu410@gmail.com"
              class="text-teal-700 hover:text-teal-900 hover:underline underline-offset-2">
              hluu410@gmail.com
            </a>
          </li>
        </ul>
      </div>
    </div>

  </div>
</section>
