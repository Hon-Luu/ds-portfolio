---
const certs = [
  {
    title: 'Claude Code in Action',
    issuer: 'Anthropic',
    issued: 'Mar 2026',
  },
  {
    title: 'LangChain for LLM Application Development',
    issuer: 'DeepLearning.AI',
    issued: 'Sep 2025',
  },
  {
    title: 'Introduction to Large Language Models',
    issuer: 'Google Cloud',
    issued: 'Sep 2025',
  },
  {
    title: 'Introduction to Generative AI',
    issuer: 'Google Cloud',
    issued: 'Sep 2025',
  },
];
---

<section id="certifications" class="py-14 bg-stone-50">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Education -->
    <h2 class="text-3xl font-bold text-stone-900 mb-2" data-reveal="up">Education</h2>
    <div class="w-8 h-0.5 bg-teal-700 mb-8" data-reveal="line"></div>

    <div class="grid sm:grid-cols-2 gap-4 mb-14" data-reveal="up" data-delay="1">
      <div class="bg-white border border-stone-200 rounded-xl p-6">
        <p class="text-xs font-mono uppercase tracking-widest text-teal-700 mb-1">Master of Science</p>
        <p class="font-semibold text-stone-900">Data Science</p>
        <p class="text-sm text-stone-500 mt-0.5">Northwestern University</p>
      </div>
      <div class="bg-white border border-stone-200 rounded-xl p-6">
        <p class="text-xs font-mono uppercase tracking-widest text-teal-700 mb-1">Bachelor of Arts</p>
        <p class="font-semibold text-stone-900">Mathematics</p>
        <p class="text-sm text-stone-500 mt-0.5">University of Oklahoma</p>
      </div>
    </div>

    <!-- Certifications -->
    <h3 class="text-lg font-semibold text-stone-900 mb-2" data-reveal="up">Certifications</h3>
    <div class="w-5 h-0.5 bg-teal-700 mb-6" data-reveal="line"></div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        certs.map((cert, i) => (
          <div
            class="bg-white border border-stone-200 rounded-xl p-5 flex flex-col gap-1 hover:border-teal-200 hover:shadow-sm transition-all"
            data-reveal="up"
            data-delay={String(i + 1)}
          >
            <p class="font-medium text-stone-900 text-sm leading-snug">{cert.title}</p>
            <p class="text-xs text-stone-500">{cert.issuer}</p>
            <p class="text-xs font-mono text-stone-400 mt-1">{cert.issued}</p>
          </div>
        ))
      }
    </div>

  </div>
</section>
