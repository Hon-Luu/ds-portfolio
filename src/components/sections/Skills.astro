---
const categories = [
  {
    name: 'Analytics & Strategy',
    primary: ['Data Strategy', 'Analytics Transformation', 'Data Governance', 'Data Products'],
    secondary: ['Data Modernization', 'Executive Reporting', 'Data Literacy'],
  },
  {
    name: 'Insurance & Domain',
    primary: ['Insurance Analytics', 'Distribution Analytics', 'Agency Analytics', 'Persistency Analytics'],
    secondary: ['Sales Productivity', 'Operational KPIs', 'Fraud Detection'],
  },
  {
    name: 'Machine Learning',
    primary: ['Predictive Modeling', 'Customer Segmentation', 'Financial Forecasting'],
    secondary: ['Machine Learning', 'Fraud Analytics', 'Retention Modeling'],
  },
  {
    name: 'Data & Engineering',
    primary: ['SQL', 'Python', 'Business Intelligence', 'Automation'],
    secondary: ['Excel', 'ETL', 'Operational Intelligence'],
  },
  {
    name: 'Leadership',
    primary: ['Analytics Team Management', 'Stakeholder Management', 'Outsourced Delivery'],
    secondary: ['Mentoring', 'Cross-functional Collaboration'],
  },
  {
    name: 'Tools & Platforms',
    primary: ['Tableau', 'Power BI', 'SQL Databases'],
    secondary: ['Python (pandas, scikit-learn)', 'Cloud Platforms', 'Reporting Automation'],
  },
];
---

<section id="skills" class="py-24">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mb-2" data-reveal="up">
      Skills
    </h2>
    <div class="w-8 h-0.5 bg-blue-600 dark:bg-blue-400 mb-3" data-reveal="line"></div>
    <p class="text-gray-500 dark:text-gray-400 mb-4 max-w-xl" data-reveal="up" data-delay="1">
      Across the full analytics lifecycle — from strategy and governance to ML and operational delivery.
    </p>
    <div
      class="flex items-center gap-4 mb-12 text-xs text-gray-400 dark:text-gray-500"
      data-reveal="up"
      data-delay="2"
    >
      <span class="flex items-center gap-1.5">
        <span class="inline-block w-3 h-3 rounded-full bg-blue-600 dark:bg-blue-500"></span>
        Core expertise
      </span>
      <span class="flex items-center gap-1.5">
        <span class="inline-block w-3 h-3 rounded-full border border-gray-300 dark:border-gray-600"></span>
        Proficient
      </span>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {
        categories.map((cat, i) => (
          <div data-reveal="up" data-delay={String(i + 1)}>
            <h3 class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-3">
              {cat.name}
            </h3>
            <ul class="flex flex-wrap gap-2">
              {cat.primary.map((skill) => (
                <li class="text-sm bg-blue-50 dark:bg-blue-950/50 text-blue-700 dark:text-blue-300 px-3 py-1 rounded-full border border-blue-200 dark:border-blue-800 font-medium">
                  {skill}
                </li>
              ))}
              {cat.secondary.map((skill) => (
                <li class="text-sm bg-transparent text-gray-600 dark:text-gray-400 px-3 py-1 rounded-full border border-gray-200 dark:border-gray-700">
                  {skill}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
