<section id="experience" class="py-14 bg-stone-50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-wrap items-baseline justify-between gap-4 mb-2">
      <h2 class="text-3xl font-bold text-stone-900" data-reveal="up">Experience</h2>
      <a
        href="/resume.pdf"
        download
        class="text-sm font-medium text-teal-700 hover:text-teal-900 hover:underline transition-colors"
        data-reveal="fade"
      >
        Download full CV (PDF) →
      </a>
    </div>
    <div class="w-8 h-0.5 bg-teal-700 mb-3" data-reveal="line"></div>
    <p class="text-stone-500 mb-12 max-w-xl" data-reveal="up" data-delay="1">
      10+ years across insurance, financial services, and adtech — US and APAC.
    </p>

    <ol class="relative border-l border-stone-200 ml-3 space-y-10">
      {
        jobs.map((job, i) => (
          <li class="pl-8 relative" data-reveal="left" data-delay={String(i + 1)}>
            <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-teal-600 bg-white" />
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-3">
              <h3 class="font-semibold text-stone-900">{job.title}</h3>
              <span class="text-stone-300">·</span>
              <span class="text-stone-600">{job.company}</span>
              <span class="text-xs text-stone-400">{job.location}</span>
              <span class="text-xs font-mono text-stone-400 ml-auto">{job.period}</span>
            </div>
            <ul class="space-y-2">
              {job.bullets.map((b) => (
                <li class="flex gap-2.5 text-sm text-stone-600">
                  <span class="text-stone-300 shrink-0 select-none mt-px">—</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>
  </div>
</section>
