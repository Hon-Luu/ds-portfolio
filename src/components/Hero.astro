---
---

<section
  id="hero"
  class="min-h-screen flex items-center pt-14"
>
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <p class="text-sm font-mono text-accent dark:text-accent-dark mb-4 tracking-widest uppercase">
      Available for new opportunities
    </p>
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-gray-900 dark:text-white leading-tight mb-6">
      Alex Chen<br />
      <span class="text-gray-500 dark:text-gray-400 font-normal">Senior Data Scientist</span>
    </h1>
    <p class="max-w-2xl text-lg md:text-xl text-gray-600 dark:text-gray-400 leading-relaxed mb-10">
      15 years turning messy data into decisions that matter. I specialise in
      machine learning, NLP, and statistical modeling — from prototype to
      production. I make complex models understandable to stakeholders and
      deployable by engineers.
    </p>
    <div class="flex flex-wrap gap-3">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 px-5 py-2.5 rounded-md text-sm font-medium hover:bg-gray-700 dark:hover:bg-gray-100 transition-colors"
      >
        View Projects
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="/ds-portfolio/resume.pdf"
        download
        class="inline-flex items-center gap-2 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 px-5 py-2.5 rounded-md text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
      >
        Download Resume
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 px-5 py-2.5 rounded-md text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
      >
        Get in Touch
      </a>
    </div>

    <!-- Quick stats -->
    <div class="mt-16 pt-12 border-t border-gray-200 dark:border-gray-800 grid grid-cols-2 sm:grid-cols-4 gap-8">
      {[
        { value: '15+', label: 'Years Experience' },
        { value: '50+', label: 'Models Deployed' },
        { value: '$10M+', label: 'Business Impact' },
        { value: '4', label: 'Industries' },
      ].map(stat => (
        <div>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">{stat.value}</p>
          <p class="text-sm text-gray-500 dark:text-gray-500 mt-1">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
