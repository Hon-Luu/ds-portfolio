---
import skills from '../content/skills.json';
---

<section id="skills" class="py-24 bg-gray-50 dark:bg-gray-900/50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="mb-12">
      <p class="text-sm font-mono text-accent dark:text-accent-dark tracking-widest uppercase mb-3">Expertise</p>
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Skills & Tools</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {Object.values(skills).map((group) => (
        <div>
          <h3 class="text-xs font-mono tracking-widest uppercase text-gray-400 dark:text-gray-500 mb-3">
            {group.label}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {group.items.map(item => (
              <li class="text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1 rounded-full">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
