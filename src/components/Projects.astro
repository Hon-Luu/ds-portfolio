---
import projects from '../content/projects.json';

const featured = projects.filter(p => p.featured);
const others = projects.filter(p => !p.featured);
---

<section id="projects" class="py-24">
  <div class="max-w-5xl mx-auto px-6">
    <div class="mb-12">
      <p class="text-sm font-mono text-accent dark:text-accent-dark tracking-widest uppercase mb-3">Work</p>
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Selected Projects</h2>
      <p class="mt-3 text-gray-500 dark:text-gray-400 max-w-xl">
        End-to-end ML systems built for production. Each project includes full engineering and stakeholder delivery.
      </p>
    </div>

    <!-- Featured projects — large cards -->
    <div class="grid md:grid-cols-2 gap-6 mb-6">
      {featured.map((project) => (
        <article class="group flex flex-col border border-gray-200 dark:border-gray-800 rounded-xl p-6 hover:border-gray-400 dark:hover:border-gray-600 transition-colors bg-gray-50/50 dark:bg-gray-900/50">
          <h3 class="font-semibold text-gray-900 dark:text-white text-lg mb-2 group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
            {project.title}
          </h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed flex-1 mb-4">
            {project.description}
          </p>
          <!-- Tool tags -->
          <ul class="flex flex-wrap gap-1.5 mb-5">
            {project.tools.map(tool => (
              <li class="text-xs font-mono bg-gray-200 dark:bg-gray-800 text-gray-700 dark:text-gray-300 px-2 py-0.5 rounded">
                {tool}
              </li>
            ))}
          </ul>
          <!-- Links -->
          <div class="flex items-center gap-4 text-sm">
            {project.github && (
              <a
                href={project.github}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors font-medium"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                GitHub
              </a>
            )}
            {project.demo && (
              <a
                href={project.demo}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors font-medium"
              >
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Live Demo
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Other projects — compact list -->
    {others.length > 0 && (
      <div class="border border-gray-200 dark:border-gray-800 rounded-xl divide-y divide-gray-200 dark:divide-gray-800">
        {others.map(project => (
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 p-5">
            <div class="flex-1">
              <h3 class="font-medium text-gray-900 dark:text-white text-sm mb-1">{project.title}</h3>
              <p class="text-xs text-gray-500 dark:text-gray-500 leading-relaxed">{project.description}</p>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
              <ul class="flex gap-1.5">
                {project.tools.slice(0, 3).map(tool => (
                  <li class="text-xs font-mono bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-1.5 py-0.5 rounded">
                    {tool}
                  </li>
                ))}
              </ul>
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
